<Page x:Class="TrucoClient.Views.CreateTournamentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Crear torneo" FontFamily="Book Antiqua" FontSize="20" Width="800" Height="600">

    <Border CornerRadius="40" BorderThickness="2" BorderBrush="#555" SnapsToDevicePixels="True">
        <Border.Background>
            <ImageBrush ImageSource="/Resources/wallpaper.png" Stretch="UniformToFill" Opacity="1"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.6" ShadowDepth="0" Color="Black"/>
        </Border.Effect>

        <Grid Margin="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Crear torneo" FontSize="40" Foreground="White" HorizontalAlignment="Left"/>
                <TextBlock Text="Seleccioná la cantidad de jugadores:" FontSize="22"
                           Foreground="#FFD4D4D4" Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Cards de selección -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 4 jugadores -->
                <Border x:Name="border4" Grid.Column="0" CornerRadius="16"
                        Background="#CC000000" BorderThickness="3" BorderBrush="#555555"
                        Cursor="Hand" MouseLeftButtonDown="ClickSelect4" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="4" FontSize="80" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Jugadores" FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="2 parejas" FontSize="18" Foreground="#FFD4D4D4"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="Semifinal + Final" FontSize="16" Foreground="#FFD4D4D4"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Card 8 jugadores -->
                <Border x:Name="border8" Grid.Column="2" CornerRadius="16"
                        Background="#CC000000" BorderThickness="3" BorderBrush="#555555"
                        Cursor="Hand" MouseLeftButtonDown="ClickSelect8" Padding="20">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="8" FontSize="80" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Jugadores" FontSize="26" Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="4 parejas" FontSize="18" Foreground="#FFD4D4D4"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <TextBlock Text="Cuartos + Semi + Final" FontSize="16" Foreground="#FFD4D4D4"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Botones inferiores -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="ClickBack" Content="Regresar" Cursor="Hand"
                        FontSize="22" Padding="15,8">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="#FFFF9595" BorderThickness="2" BorderBrush="#FFBF3333">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="btnCreate" Grid.Column="2" Click="ClickCreate"
                        Content="CREAR TORNEO" Cursor="Hand" FontSize="22" FontWeight="Bold"
                        Padding="25,8" IsEnabled="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10" Background="#FF2EF457" BorderThickness="2" BorderBrush="#FF03D400">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="1"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Page>