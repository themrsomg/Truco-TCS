<Page x:Class="TrucoClient.Views.TournamentBracketsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Partidas de torneo" FontFamily="Book Antiqua" FontSize="20" Width="800" Height="600">

    <Border CornerRadius="40" BorderThickness="2" BorderBrush="#555" SnapsToDevicePixels="True">
        <Border.Background>
            <ImageBrush ImageSource="/Resources/wallpaper.png" Stretch="UniformToFill" Opacity="1"/>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.6" ShadowDepth="0" Color="Black"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Partidas de torneo" FontSize="40" Foreground="White"
                         HorizontalAlignment="Left" Margin="0,0,0,20"/>

            <Border x:Name="NotificationBorder" Grid.Row="0" Background="#E6FFFFFF" CornerRadius="10"
                      HorizontalAlignment="Right" VerticalAlignment="Top" Padding="15"
                      Visibility="Collapsed" BorderThickness="2" BorderBrush="#FF2EF457">
                <StackPanel>
                    <TextBlock Text="Tu partida está a punto de" Foreground="Black" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="comenzar..." Foreground="Black" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Bracket 4 jugadores: Semis → Final -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="210"/>
                </Grid.ColumnDefinitions>

                <!-- Semifinal 1 (izquierda) -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,20">
                    <TextBlock Text="Semifinal 1" Foreground="White" HorizontalAlignment="Center"
                                 FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Border x:Name="brdSF1_P1" Background="#E6FFFFFF" CornerRadius="8" Margin="0,5" Padding="10">
                        <TextBlock x:Name="txtSF1_P1" Text="TBD" Foreground="Black"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VS" Foreground="White" HorizontalAlignment="Center"
                                 FontSize="14" Margin="0,6"/>
                    <Border x:Name="brdSF1_P2" Background="#E6FFFFFF" CornerRadius="8" Margin="0,5" Padding="10">
                        <TextBlock x:Name="txtSF1_P2" Text="TBD" Foreground="Black"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>

                <!-- Final (centro) -->
                <Border Grid.Column="1" Background="#FFF3C754" BorderThickness="3"
                          BorderBrush="#FFDDA81C" CornerRadius="15" Margin="25,80" Padding="15">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="FINAL" Foreground="Black" HorizontalAlignment="Center"
                                     FontWeight="Bold" FontSize="18" Margin="0,0,0,14"/>
                        <Border x:Name="brdF1" Background="Transparent" CornerRadius="5" Padding="4">
                            <TextBlock x:Name="txtFinal1" Text="TBD" Foreground="Black"
                                         FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="VS" Foreground="Black" HorizontalAlignment="Center"
                                     FontSize="18" Margin="0,8"/>
                        <Border x:Name="brdF2" Background="Transparent" CornerRadius="5" Padding="4">
                            <TextBlock x:Name="txtFinal2" Text="TBD" Foreground="Black"
                                         FontWeight="Bold" HorizontalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Semifinal 2 (derecha) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,20">
                    <TextBlock Text="Semifinal 2" Foreground="White" HorizontalAlignment="Center"
                                 FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                    <Border x:Name="brdSF2_P1" Background="#E6FFFFFF" CornerRadius="8" Margin="0,5" Padding="10">
                        <TextBlock x:Name="txtSF2_P1" Text="TBD" Foreground="Black"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="VS" Foreground="White" HorizontalAlignment="Center"
                                 FontSize="14" Margin="0,6"/>
                    <Border x:Name="brdSF2_P2" Background="#E6FFFFFF" CornerRadius="8" Margin="0,5" Padding="10">
                        <TextBlock x:Name="txtSF2_P2" Text="TBD" Foreground="Black"
                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Page>