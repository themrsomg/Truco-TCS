<Page x:Class="TrucoClient.Views.TournamentBracketsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Partidas de torneo" FontFamily="Book Antiqua" FontSize="20" Width="800" Height="600">

    <Border CornerRadius="40" BorderThickness="2" BorderBrush="#555" SnapsToDevicePixels="True">
        <Border.Background>
            <ImageBrush ImageSource="/Resources/wallpaper.png" Stretch="UniformToFill" Opacity="1"/>
        </Border.Background>

        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Opacity="0.6" ShadowDepth="0" Color="Black"/>
        </Border.Effect>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Partidas de torneo" FontSize="40" Foreground="White" 
                       HorizontalAlignment="Left" Margin="0,0,0,20"/>

            <Border x:Name="NotificationBorder" Grid.Row="0" Background="#E6FFFFFF" CornerRadius="10" HorizontalAlignment="Right" 
                    VerticalAlignment="Top" Padding="15" Visibility="Collapsed" BorderThickness="2" BorderBrush="#FF2EF457">
                <StackPanel>
                    <TextBlock Text="Tu partida está a punto de" Foreground="Black" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="comenzar..." Foreground="Black" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cuartos Izquierda -->
                <Border x:Name="brdP1" Grid.Row="0" Grid.Column="0" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP1" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="brdP2" Grid.Row="1" Grid.Column="0" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP2" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="brdP3" Grid.Row="2" Grid.Column="0" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP3" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="brdP4" Grid.Row="3" Grid.Column="0" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP4" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>

                <!-- Semis Izquierda -->
                <Border x:Name="brdS1" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Background="#E6FFFFFF" CornerRadius="8" Margin="10,50" Padding="5">
                    <TextBlock x:Name="txtS1" Text="TBD" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="brdS2" Grid.Row="2" Grid.RowSpan="2" Grid.Column="1" Background="#E6FFFFFF" CornerRadius="8" Margin="10,50" Padding="5">
                    <TextBlock x:Name="txtS2" Text="TBD" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Final Centro -->
                <Border x:Name="brdF1" Grid.Row="1" Grid.RowSpan="2" Grid.Column="2" Background="#FFF3C754" BorderThickness="3" BorderBrush="#FFDDA81C" CornerRadius="15" Margin="10,30" Padding="10">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtFinal1" Text="TBD" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="VS" Foreground="Black" HorizontalAlignment="Center" FontSize="18"/>
                        <TextBlock x:Name="txtFinal2" Text="TBD" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Semis Derecha -->
                <Border x:Name="brdS3" Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Background="#E6FFFFFF" CornerRadius="8" Margin="10,50" Padding="5">
                    <TextBlock x:Name="txtS3" Text="TBD" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="brdS4" Grid.Row="2" Grid.RowSpan="2" Grid.Column="3" Background="#E6FFFFFF" CornerRadius="8" Margin="10,50" Padding="5">
                    <TextBlock x:Name="txtS4" Text="TBD" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Cuartos Derecha -->
                <Border x:Name="brdP5" Grid.Row="0" Grid.Column="4" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP5" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="brdP6" Grid.Row="1" Grid.Column="4" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP6" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="brdP7" Grid.Row="2" Grid.Column="4" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP7" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border x:Name="brdP8" Grid.Row="3" Grid.Column="4" Background="#E6FFFFFF" CornerRadius="8" Margin="0,15" Padding="10">
                    <TextBlock x:Name="txtP8" Text="TBD" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Page>